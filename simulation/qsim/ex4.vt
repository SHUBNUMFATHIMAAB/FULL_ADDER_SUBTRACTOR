// *****************************************************************************
// This file contains a Verilog test bench with test vectors .The test vectors  
// are exported from a vector file in the Quartus Waveform Editor and apply to  
// the top level entity of the current Quartus project .The user can use this   
// testbench to simulate his design using a third-party simulation tool .       
// *****************************************************************************
// Generated on "05/27/2026 13:46:46"
                                                                        
// Verilog Self-Checking Test Bench (with test vectors) for design :    ex4
// 
// Simulation tool : 3rd Party
// 

`timescale 1 ps/ 1 ps
module ex4_vlg_sample_tst(
	A,
	B,
	Bin,
	Cin,
	sampler_tx
);
input  A;
input  B;
input  Bin;
input  Cin;
output sampler_tx;

reg sample;
time current_time;
always @(A or B or Bin or Cin)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

module ex4_vlg_check_tst (
	Borrow,
	Carry,
	Diff,
	Sum,
	sampler_rx
);
input  Borrow;
input  Carry;
input  Diff;
input  Sum;
input sampler_rx;

reg  Borrow_expected;
reg  Carry_expected;
reg  Diff_expected;
reg  Sum_expected;

reg  Borrow_prev;
reg  Carry_prev;
reg  Diff_prev;
reg  Sum_prev;

reg  Borrow_expected_prev;
reg  Carry_expected_prev;
reg  Diff_expected_prev;
reg  Sum_expected_prev;

reg  last_Borrow_exp;
reg  last_Carry_exp;
reg  last_Diff_exp;
reg  last_Sum_exp;

reg trigger;

integer i;
integer nummismatches;

reg [1:4] on_first_change ;


initial
begin
trigger = 0;
i = 0;
nummismatches = 0;
on_first_change = 4'b1;
end

// update real /o prevs

always @(trigger)
begin
	Borrow_prev = Borrow;
	Carry_prev = Carry;
	Diff_prev = Diff;
	Sum_prev = Sum;
end

// update expected /o prevs

always @(trigger)
begin
	Borrow_expected_prev = Borrow_expected;
	Carry_expected_prev = Carry_expected;
	Diff_expected_prev = Diff_expected;
	Sum_expected_prev = Sum_expected;
end



// expected Borrow
initial
begin
	Borrow_expected = 1'bX;
end 

// expected Carry
initial
begin
	Carry_expected = 1'bX;
end 

// expected Diff
initial
begin
	Diff_expected = 1'bX;
end 

// expected Sum
initial
begin
	Sum_expected = 1'bX;
end 
// generate trigger
always @(Borrow_expected or Borrow or Carry_expected or Carry or Diff_expected or Diff or Sum_expected or Sum)
begin
	trigger <= ~trigger;
end

always @(posedge sampler_rx or negedge sampler_rx)
begin
`ifdef debug_tbench
	$display("Scanning pattern %d @time = %t",i,$realtime );
	i = i + 1;
	$display("| expected Borrow = %b | expected Carry = %b | expected Diff = %b | expected Sum = %b | ",Borrow_expected_prev,Carry_expected_prev,Diff_expected_prev,Sum_expected_prev);
	$display("| real Borrow = %b | real Carry = %b | real Diff = %b | real Sum = %b | ",Borrow_prev,Carry_prev,Diff_prev,Sum_prev);
`endif
	if (
		( Borrow_expected_prev !== 1'bx ) && ( Borrow_prev !== Borrow_expected_prev )
		&& ((Borrow_expected_prev !== last_Borrow_exp) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Borrow :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Borrow_expected_prev);
		$display ("     Real value = %b", Borrow_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_Borrow_exp = Borrow_expected_prev;
	end
	if (
		( Carry_expected_prev !== 1'bx ) && ( Carry_prev !== Carry_expected_prev )
		&& ((Carry_expected_prev !== last_Carry_exp) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Carry :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Carry_expected_prev);
		$display ("     Real value = %b", Carry_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_Carry_exp = Carry_expected_prev;
	end
	if (
		( Diff_expected_prev !== 1'bx ) && ( Diff_prev !== Diff_expected_prev )
		&& ((Diff_expected_prev !== last_Diff_exp) ||
			on_first_change[3])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Diff :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Diff_expected_prev);
		$display ("     Real value = %b", Diff_prev);
		nummismatches = nummismatches + 1;
		on_first_change[3] = 1'b0;
		last_Diff_exp = Diff_expected_prev;
	end
	if (
		( Sum_expected_prev !== 1'bx ) && ( Sum_prev !== Sum_expected_prev )
		&& ((Sum_expected_prev !== last_Sum_exp) ||
			on_first_change[4])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Sum :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Sum_expected_prev);
		$display ("     Real value = %b", Sum_prev);
		nummismatches = nummismatches + 1;
		on_first_change[4] = 1'b0;
		last_Sum_exp = Sum_expected_prev;
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#100000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module ex4_vlg_vec_tst();
// constants                                           
// general purpose registers
reg A;
reg B;
reg Bin;
reg Cin;
// wires                                               
wire Borrow;
wire Carry;
wire Diff;
wire Sum;

wire sampler;                             

// assign statements (if any)                          
ex4 i1 (
// port map - connection between master ports and signals/registers   
	.A(A),
	.B(B),
	.Bin(Bin),
	.Borrow(Borrow),
	.Carry(Carry),
	.Cin(Cin),
	.Diff(Diff),
	.Sum(Sum)
);

// A
initial
begin
	A = 1'b0;
	A = #10000 1'b1;
	A = #10000 1'b0;
end 

// B
initial
begin
	B = 1'b0;
	B = #10000 1'b1;
	B = #10000 1'b0;
	B = #10000 1'b1;
	B = #10000 1'b0;
	B = #10000 1'b1;
	B = #10000 1'b0;
end 

// Bin
initial
begin
	Bin = 1'b0;
	Bin = #30000 1'b1;
	Bin = #10000 1'b0;
end 

// Cin
initial
begin
	Cin = 1'b0;
	Cin = #10000 1'b1;
	Cin = #10000 1'b0;
	Cin = #10000 1'b1;
	Cin = #10000 1'b0;
	Cin = #10000 1'b1;
	Cin = #10000 1'b0;
end 

ex4_vlg_sample_tst tb_sample (
	.A(A),
	.B(B),
	.Bin(Bin),
	.Cin(Cin),
	.sampler_tx(sampler)
);

ex4_vlg_check_tst tb_out(
	.Borrow(Borrow),
	.Carry(Carry),
	.Diff(Diff),
	.Sum(Sum),
	.sampler_rx(sampler)
);
endmodule

